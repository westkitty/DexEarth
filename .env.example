# ─── DexEarth Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# NASA FIRMS API key — required for the THERMAL_FIRES layer.
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Leave blank or set to placeholder to run without fires data.
VITE_FIRMS_MAP_KEY=YOUR_KEY_HERE
